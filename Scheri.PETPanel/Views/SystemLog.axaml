<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:viewModels="clr-namespace:Scheri.PETPanel.ViewModels"
			 x:DataType="viewModels:SystemOverviewViewModel"
			 x:Class="Scheri.PETPanel.SystemLog">
	<Grid>
		<DataGrid Margin="20" ItemsSource="{Binding LogRecords}"
				  GridLinesVisibility="All"
				  BorderThickness="1" BorderBrush="Gray">
			<DataGrid.Columns>
				<DataGridTextColumn Header="First Name"/>
				<DataGridTextColumn Header="Last Name"/>
				<DataGridCheckBoxColumn Header="Fictitious?" />
			</DataGrid.Columns>
		</DataGrid>
	</Grid>
</UserControl>
