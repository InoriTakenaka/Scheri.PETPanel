<Styles xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:componentmodel="using:System.ComponentModel"
		xmlns:cp="using:Scheri.PETPanel.UIComponents">
	<Design.PreviewWith>

		<Border Padding="20">
			<!-- Add Controls for Previewer Here -->
		</Border>
	</Design.PreviewWith>

	<Style Selector="cp|TileControl">
		<Setter Property="VerticalAlignment" Value="Stretch"/>
		<Setter Property="HorizontalAlignment" Value="Stretch"/>
		<Setter Property="Margin" Value="8"/>
		<Setter Property="Template">
			<ControlTemplate>
				<Button x:Name="PART_TileButton"
						Background="Transparent"
						BorderThickness="0"
						CornerRadius="100"
						Padding="0"
						HorizontalAlignment="Stretch"
						VerticalAlignment="Stretch">

					<Grid ClipToBounds="True">

						<Border CornerRadius="100">
							<Border.Background>
								<SolidColorBrush Color="{Binding BackgroundEnd, RelativeSource={RelativeSource TemplatedParent}}"/>
							</Border.Background>
						</Border>

						<!-- 第二层：线性渐变 (产生明暗过渡) -->
						<Border CornerRadius="100">
							<Border.Background>
								<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
									<GradientStop Offset="0.0" Color="{Binding BackgroundStart, RelativeSource={RelativeSource TemplatedParent}}"/>
									<GradientStop Offset="0.4" Color="{Binding BackgroundEnd, RelativeSource={RelativeSource TemplatedParent}}"/>
								</LinearGradientBrush>
							</Border.Background>
						</Border>

						<!-- 第三层：高光切面 (高度务必限制在 180 左右，不要 450) -->
						<Border Height="180"
								VerticalAlignment="Top"
								CornerRadius="100,100,500,500"
								Opacity="0.35">
							<Border.Background>
								<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
									<GradientStop Color="White" Offset="0.0"/>
									<GradientStop Color="Transparent" Offset="0.9"/>
								</LinearGradientBrush>
							</Border.Background>
						</Border>

						<!-- 3. 内容层 -->
						<Grid RowDefinitions="*,Auto" Margin="40">
							<!-- 放置图标 -->
							<ContentPresenter Grid.Row="0"
											  Content="{TemplateBinding Content}"
											  HorizontalAlignment="Center"
											  VerticalAlignment="Center"/>

							<!-- 放置标签文字 -->
							<TextBlock Grid.Row="1"
									   Text="{TemplateBinding Label}"
									   Foreground="White"
									   FontSize="48"
									   FontWeight="ExtraBold"
									   HorizontalAlignment="Center"
									   Margin="0,0,0,30">
								<TextBlock.Effect>
									<DropShadowEffect BlurRadius="15" Opacity="0.6" OffsetX="0" OffsetY="4"/>
								</TextBlock.Effect>
							</TextBlock>
						</Grid>

				</Grid>
				</Button>
			</ControlTemplate>

		</Setter>
	</Style>
</Styles>
