<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="Scheri.PETPanel.UIComponents.Views.AppTitle">
	<Grid Height="60" Background="#1E1E1E">
		<StackPanel VerticalAlignment="Stretch" HorizontalAlignment="Right"
                    Orientation="Horizontal" Spacing="10">
            <TextBlock x:Name="SystemTime" FontFamily="{StaticResource DigitalNumbersFont}" FontSize="20"
                       Foreground="White" VerticalAlignment="Center"
                       TextAlignment="Right" />
        </StackPanel>
	</Grid>
</UserControl>
