<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="60"
			 x:Class="Scheri.PETPanel.UIComponents.StatusBar">
	<UserControl.Styles>
		<Style Selector="TextBlock">
			<Setter Property="Foreground" Value="#5A7D9A" />
			<Setter Property="FontFamily" Value="{StaticResource GOST}" />
			<Setter Property="FontSize" Value="18" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>
	</UserControl.Styles>
	<Grid Height="60" Background="#D1D9E1"> <!-- 使用液态铝色，略深于主背景以示区分 -->
	<!-- 顶部分割线：强化与上方内容区的界限 -->
	<Border BorderBrush="#B0B8C1" BorderThickness="0,1,0,0" VerticalAlignment="Top"/>

		<StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20,0">

			<!-- 晶体温度监测 -->
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
				<TextBlock Text="CRYSTAL TEMP"
						   FontSize="22"
						   FontWeight="Bold"
						   Margin="0,0,8,0"/>
				<!-- 实时数值：使用加粗的板岩蓝或翡翠绿 -->
				<TextBlock x:Name="CrystalTempText"
						   Text="25.4 ℃"
						   FontFamily="{StaticResource DigitalNumbersFont}"/>
			</StackPanel>

			<!-- 垂直分割线 -->
			<Border Width="1" Height="20" Background="#B0B8C1" Margin="25,0"/>

			<!-- 计数率监测 -->
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
				<TextBlock Text="COUNT RATE"
						   FontSize="22"
						   FontWeight="Bold"
						   Margin="0,0,8,0"/>
				<!-- 计数率数值 -->
				<TextBlock x:Name="CountRateText" Text="120 %"
						   FontFamily="{StaticResource DigitalNumbersFont}"/>
			</StackPanel>

			<!-- 垂直分割线 -->
			<Border Width="1" Height="20" Background="#B0B8C1" Margin="25,0"/>

			<!-- 运行状态指示灯 -->
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="30,0,0,0">
				<Ellipse Width="10" Height="10" Fill="#50FA7B" Margin="0,0,8,0">
					<Ellipse.Effect>
						<DropShadowEffect BlurRadius="5" Color="#50FA7B" Opacity="0.5"/>
					</Ellipse.Effect>
				</Ellipse>
				<TextBlock Text="SYSTEM READY"/>
			</StackPanel>
		</StackPanel>
	</Grid>
</UserControl>
