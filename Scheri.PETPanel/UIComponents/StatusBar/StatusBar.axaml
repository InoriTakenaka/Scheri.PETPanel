<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Scheri.PETPanel.UIComponents"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="60"
             x:Class="Scheri.PETPanel.UIComponents.StatusBar"
             x:DataType="vm:StatusPanelViewModel">
    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#5A7D9A" />
            <Setter Property="FontFamily" Value="{StaticResource GOST}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Styles>
    <UserControl.DataContext>
        <vm:StatusPanelViewModel />
    </UserControl.DataContext>
    <Grid Height="60" Background="#D1D9E1">
        <Border BorderBrush="#B0B8C1" BorderThickness="0,1,0,0" VerticalAlignment="Top" />

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20,0">

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="CRYSTAL TEMP" FontSize="22" FontWeight="Bold" Margin="0,0,8,0" />

                <TextBlock x:Name="CrystalTempText"
                           Text="{Binding CrystalAvgTemprature}"
                           FontFamily="{StaticResource DigitalNumbersFont}" />
            </StackPanel>

            <Border Width="1" Height="20" Background="#B0B8C1" Margin="25,0" />

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="COUNT RATE" FontSize="22" FontWeight="Bold" Margin="0,0,8,0" />

                <TextBlock x:Name="CountRateText" Text="{Binding PromptCount}"
                           FontFamily="{StaticResource DigitalNumbersFont}" />
            </StackPanel>

            <Border Width="1" Height="20" Background="#B0B8C1" Margin="25,0" />

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="30,0,0,0">
                <Ellipse Width="10" Height="10" Margin="0,0,8,0" Tag="{Binding IsConnected}" Name="StatusLamp">

                    <Ellipse.Styles>
                        <!-- default status: network disconnected -->
                        <Style Selector="Ellipse">
                            <Setter Property="Fill" Value="#ff5555" />
                            <Setter Property="Effect">
                                <DropShadowEffect BlurRadius="5" Color="#ff5555" Opacity="0.5" />
                            </Setter>
                        </Style>
                        <!-- active status: network connected -->
                        <Style Selector="Ellipse[Tag=True]">
                            <Setter Property="Fill" Value="#50fa7b" />
                            <Setter Property="Effect">
                                <DropShadowEffect BlurRadius="5" Color="#50fa7b" Opacity="0.5" />
                            </Setter>
                        </Style>
                    </Ellipse.Styles>
                </Ellipse>
                <TextBlock Text="SYSTEM READY" FontSize="22" FontWeight="Bold" Name="StatusText" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>