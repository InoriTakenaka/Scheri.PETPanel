<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:f="using:FluentIcons.Avalonia">
  <Design.PreviewWith>
    <Border Padding="20">
      <!-- Add Controls for Previewer Here -->
    </Border>
  </Design.PreviewWith>

  <!-- Button style for device control buttons -->
		<Style Selector="Button.DeviceControl">
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="VerticalAlignment" Value="Stretch" />
			<Setter Property="Padding" Value="20" />
			<Setter Property="BorderBrush" Value="#5A7D9A"/>
			<Setter Property="Background" Value="#F0F4F8" />
			<Setter Property="HorizontalContentAlignment" Value="Center" />
			<Setter Property="VerticalContentAlignment" Value="Center" />
			<Setter Property="BorderThickness" Value="2" />
			<Setter Property="CornerRadius" Value="4" />
		</Style>
		<Style Selector="Button.DeviceControl > StackPanel">
			<Setter Property="Spacing" Value="15" />
		</Style>
		<Style Selector="Button.DeviceControl f|SymbolIcon">
			<Setter Property="FontSize" Value="56" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>
		<Style Selector="Button.DeviceControl TextBlock">
			<Setter Property="FontSize" Value="56" />
			<Setter Property="FontFamily" Value="{DynamicResource GOST}" />
			<Setter Property="FontWeight" Value="SemiBold" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>


		<Style Selector="Button.DeviceControl > StackPanel">
			<Setter Property="Spacing" Value="15" />
		</Style>
		<Style Selector="Button.DeviceControl f|SymbolIcon">
			<Setter Property="FontSize" Value="56" />
			<Setter Property="Foreground" Value="#5A7D9A" />
		</Style>
		<Style Selector="Button.DeviceControl TextBlock">
			<Setter Property="FontSize" Value="56" />
			<Setter Property="FontFamily" Value="{DynamicResource GOST}" />
			<Setter Property="FontWeight" Value="SemiBold" />
		</Style>

		<Style Selector="Button.DeviceControl:pressed /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="#B3FFB86C" />
			<Setter Property="BorderBrush" Value="#FF8C00" />
			<Setter Property="BoxShadow" Value="0 2 10 0 #4D000000" />
	</Style>
		<Style Selector="Button.DeviceControl:pressed">
			<Setter Property="Effect">
				<Setter.Value>
					<DropShadowEffect BlurRadius="25" Color="#FFB86C" Opacity="0.8" OffsetX="0" OffsetY="0" />
				</Setter.Value>
			</Setter>
		</Style>

		<Style Selector="Button.DeviceControl:pressed TextBlock">
			<Setter Property="Foreground" Value="#FFFFFF" />
		</Style>
		<Style Selector="Button.DeviceControl:pressed f|SymbolIcon">
			<Setter Property="Foreground" Value="#FFFFFF" />
		</Style>
		<!-- end -->
</Styles>
