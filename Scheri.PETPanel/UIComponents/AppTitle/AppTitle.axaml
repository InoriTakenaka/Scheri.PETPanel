<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="60"
			 x:Class="Scheri.PETPanel.UIComponents.AppTitle">
	<Grid Height="60" Background="#D1D9E1">
		<Border BorderBrush="#B0B8C1" BorderThickness="0,0,0,1" VerticalAlignment="Bottom">
		<StackPanel VerticalAlignment="Stretch" HorizontalAlignment="Right"
                    Orientation="Horizontal" Spacing="10">
            <TextBlock x:Name="SystemTime" FontFamily="{StaticResource DigitalNumbersFont}" FontSize="24"
                       Foreground="#5A7D9A" TextAlignment="Right" Margin="0 0 10 10"/>
        </StackPanel>
		</Border>		
	</Grid>
</UserControl>
