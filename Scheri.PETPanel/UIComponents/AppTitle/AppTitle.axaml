<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="60"
			 x:Class="Scheri.PETPanel.UIComponents.AppTitle">
	<Grid Height="60" Background="#D1D9E1">
		<Border BorderBrush="#B0B8C1" BorderThickness="0,0,0,1" VerticalAlignment="Bottom">
			<Grid Margin="10,5,10,5">
				<TextBlock Text="No patient registred." HorizontalAlignment="Left"
						   VerticalAlignment="Top" LetterSpacing="2" Foreground="#5A7D9A"
						   FontSize="36" FontFamily="{StaticResource GOST}" FontWeight="Bold"/>
			</Grid>
		</Border>
	</Grid>
</UserControl>
