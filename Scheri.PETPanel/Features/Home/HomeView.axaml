<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:cp ="using:Scheri.PETPanel.UIComponents"
			 x:Class="Scheri.PETPanel.Features.HomeView">
	<Grid RowDefinitions="*,*" ColumnDefinitions="*,*,*" Margin="10">
		<cp:TileControl Grid.Row="0" Grid.Column="0" Label="设置"/>
		<cp:TileControl Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Label="设置"/>	
	</Grid>
</UserControl>
