<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:cp="clr-namespace:Scheri.PETPanel.UIComponents"
             cp:ViewProps.Title="CAMERA"
             x:Class="Scheri.PETPanel.Features.CameraView">
  <Grid Background="Black">
	  <Image x:Name="VideoFrame" Stretch="Fill"/>
      <TextBlock Text="CONNECTING..." Margin="0,30,0,0" HorizontalAlignment="Center" Foreground="Silver" FontSize="30" 
                 FontFamily="{StaticResource GOST}" FontWeight="Bold"/>
  </Grid>
</UserControl>
