<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:features="using:Scheri.PETPanel.Features"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
              xmlns:cp="clr-namespace:Scheri.PETPanel.UIComponents"
             cp:ViewProps.Title="CAMERA"
             x:Class="Scheri.PETPanel.Features.CameraPlay">
  <Grid>
	  <features:CameraView x:Name="CameraView"/>
  </Grid>
</UserControl>
