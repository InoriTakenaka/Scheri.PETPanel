<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="Scheri.PETPanel.Camera.SimpleMediaPlayer">
	<Grid>
		<Image x:Name="ImgVideo" Stretch="Fill" />
		<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
						<TextBlock Text="NO SIGNAL"
								   FontSize="32"
								   FontWeight="Bold"
								   FontFamily="{StaticResource GOST}"
								   Foreground="#FFB86C">
							<TextBlock.Effect>
								<DropShadowEffect BlurRadius="10" Color="#FFB86C" Opacity="0.5" />
							</TextBlock.Effect>
						</TextBlock>

						<TextBlock Text="CHECKING CONNECTION..."
								   FontSize="24"
								   HorizontalAlignment="Center"
								   FontFamily="{StaticResource GOST}"
								   FontWeight="SemiBold"
								   Foreground="#80FFB86C"
								   Margin="0,5,0,0"/>
					</StackPanel>
	</Grid>
</UserControl>
